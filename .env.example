# OneSignal Push Notifications Configuration
# Get these values from your OneSignal dashboard (https://onesignal.com)

# Frontend Configuration (must be prefixed with VITE_)
VITE_ONESIGNAL_APP_ID=your_onesignal_app_id_here

# Backend Configuration
ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_API_KEY=your_onesignal_rest_api_key_here

# Database Configuration
DATABASE_URL=your_database_url_here

# Session Configuration  
SESSION_SECRET=your_session_secret_here

# Node Environment
NODE_ENV=development

# Stripe Payment Processing Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Frontend Stripe Configuration (must be prefixed with VITE_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
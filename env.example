# Environment Configuration Template
# For local or VPS deployment, rename this to .env and fill in the values.
# DO NOT commit the actual .env file to version control.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/italklink

# Security
SESSION_SECRET=your_random_secret_here

# Stripe (Payments)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# OpenAI (AI features & Voice)
OPENAI_API_KEY=sk-proj-...

# SendGrid (Emails)
SENDGRID_API_KEY=SG....

# Twilio (SMS - Optional)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+1234567890

# Replit Object Storage (Internal - usually handled by Replit)
# For local/VPS, you may need to configure an alternative like AWS S3
# and update server/objectStorage.ts accordingly.
